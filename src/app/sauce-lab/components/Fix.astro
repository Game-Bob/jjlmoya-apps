---
import type { SauceLabFix } from '../types';

interface Props {
    t: SauceLabFix;
    appId: string;
}

const { t, appId } = Astro.props;
---

<section class="sl-fix">
    <div class="sl-container">
        <div class="sl-fix-grid">
            <div class="sl-fix-content">
                <span class="sl-label">{t.label}</span>
                <h2 class="sl-section-title">
                    {t.titleMain} <span class="sl-text-accent">{t.titleHighlight}</span>
                </h2>
                <p class="sl-text">{t.description}</p>
                <div class="sl-fix-steps-column">
                    {t.steps.map((step, i) => (
                        <div class:list={["sl-fix-step-item", { 'active': i === 1 }]}>
                            <span class="sl-fix-step-num">{step.num}</span>
                            <div class="sl-fix-step-info">
                                <h3 class="sl-fix-step-title">{step.title}</h3>
                                <p class="sl-fix-step-text">{step.description}</p>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
            <div class="sl-fix-visual">
                <div class="sl-phone-mockup">
                    <img src={`/assets/apps/${appId}/screenshots/fix.webp`} alt="Fix Mode" class="sl-screenshot" />
                </div>
            </div>
        </div>
    </div>
</section>
