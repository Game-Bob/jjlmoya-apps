---
import type { SauceLabHierarchy } from '../types';

interface Props {
    t: SauceLabHierarchy;
    appId: string;
}

const { t, appId } = Astro.props;

const getSauceId = (name: string) => {
    const map: Record<string, string> = {
        'Béchamel': 'bechamel',
        'Velouté': 'veloute',
        'Espagnole': 'espagnole',
        'Tomato': 'tomate',
        'Tomate': 'tomate',
        'Hollandaise': 'hollandaise'
    };
    return map[name] || '';
};
---

<section class="sl-hierarchy">
    <div class="sl-container">
        <div class="sl-hierarchy-header">
            <span class="sl-label">{t.label}</span>
            <h2 class="sl-section-title">
                {t.titleMain} <span class="sl-text-accent">{t.titleHighlight}</span>
            </h2>
            <p class="sl-text">{t.description}</p>
        </div>
        
        <div class="sl-hierarchy-layout">
            <div class="sl-hierarchy-grid">
                {t.items.map((item) => (
                    <div class="sl-hierarchy-card" data-sauce={getSauceId(item.name)}>
                        <div class="sl-hierarchy-card-bg-bubble"></div>
                        <div class="sl-hierarchy-card-content">
                            <div class="sl-hierarchy-card-header">
                                <h3 class="sl-hierarchy-name">{item.name}</h3>
                                <span class="sl-hierarchy-base">{item.base}</span>
                            </div>
                            <div class="sl-hierarchy-derivatives">
                                {item.derivatives.map((der) => (
                                    <span class="sl-derivative-tag">{der}</span>
                                ))}
                            </div>
                        </div>
                    </div>
                ))}
            </div>
            <div class="sl-hierarchy-visual">
                <div class="sl-phone-mockup">
                    <img src={`/assets/apps/${appId}/screenshots/recipe.webp`} alt="Sauce Recipe" class="sl-screenshot" />
                </div>
            </div>
        </div>
    </div>
</section>
