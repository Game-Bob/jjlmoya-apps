---
import { Icon } from 'astro-icon/components';
import type { SauceLabHero } from '../types';

interface Props {
    t: SauceLabHero;
    appId: string;
    stores: {
        googlePlay?: string;
        appStore?: string;
    };
}

const { t, appId, stores } = Astro.props;

const hasGooglePlay = !!stores.googlePlay;
const hasAppStore = !!stores.appStore;
---

<section class="sl-hero">
    <div class="sl-hero-inner">
        <div class="sl-hero-badge">
            <span class="sl-hero-badge-dot"></span>
            {t.priceLabel}
        </div>
        
        <div class="sl-hero-content">
            <h1 class="sl-hero-title">
                {t.title.split(' ').map((word, i) => (
                    <span class={i === t.title.split(' ').length - 1 ? 'sl-hero-title-accent' : ''}>{word} </span>
                ))}
            </h1>
            <p class="sl-hero-subtitle">{t.subtitle}</p>
        </div>

        <div class="sl-hero-icon-container">
            <div class="sl-bubble-decoration sl-bubble-1"></div>
            <div class="sl-bubble-decoration sl-bubble-2"></div>
            <img src={`/assets/apps/${appId}/icon.webp`} alt="SauceLab Icon" class="sl-hero-icon" />
            <div class="sl-hero-icon-glow"></div>
        </div>

        <div class="sl-hero-actions">
            <div class:list={["sl-btn-wrapper", { 'disabled': !hasAppStore }]}>
                <a href={hasAppStore ? stores.appStore : 'javascript:void(0)'} class="sl-btn sl-btn-primary">
                    <Icon name="mdi:apple" class="sl-btn-icon" />
                    <span>App Store</span>
                </a>
                {!hasAppStore && <span class="sl-btn-status">{t.comingSoon}</span>}
            </div>

            <div class:list={["sl-btn-wrapper", { 'disabled': !hasGooglePlay }]}>
                <a href={hasGooglePlay ? stores.googlePlay : 'javascript:void(0)'} class="sl-btn sl-btn-secondary">
                    <Icon name="mdi:google-play" class="sl-btn-icon" />
                    <span>Google Play</span>
                </a>
                {!hasGooglePlay && <span class="sl-btn-status">{t.comingSoon}</span>}
            </div>
        </div>
        
        <div class="sl-hero-scroll">
            <div class="sl-scroll-line"></div>
        </div>
    </div>
</section>
