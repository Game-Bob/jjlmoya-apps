---
import type { SauceLabPhilosophy } from '../types';

interface Props {
    t: SauceLabPhilosophy;
    appId: string;
}

const { t, appId } = Astro.props;
---

<section class="sl-philosophy">
    <div class="sl-container">
        <div class="sl-philosophy-grid">
            <div class="sl-philosophy-content">
                <span class="sl-label">{t.label}</span>
                <h2 class="sl-philosophy-title">{t.title}</h2>
                <p class="sl-philosophy-text">{t.description}</p>
                <div class="sl-philosophy-stats">
                    <div class="sl-stat">
                        <span class="sl-stat-num">100+</span>
                        <span class="sl-stat-label">Recipes</span>
                    </div>
                    <div class="sl-stat">
                        <span class="sl-stat-num">15</span>
                        <span class="sl-stat-label">Locales</span>
                    </div>
                </div>
            </div>
            <div class="sl-philosophy-visual">
                <div class="sl-phone-mockup">
                    <img src={`/assets/apps/${appId}/screenshots/features.webp`} alt="SauceLab Features" class="sl-screenshot" />
                </div>
            </div>
        </div>
    </div>
</section>
