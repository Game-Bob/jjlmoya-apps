---
import { Icon } from 'astro-icon/components';
import type { FortuneCookieStreak } from '../types';

interface Props {
    t: FortuneCookieStreak;
    appId: string;
}

const { t, appId } = Astro.props;

const imgMap: { [key: number]: string } = { 2: 'cookie-moon.webp', 5: 'cookie-crystal.webp', 8: 'cookie-moon.webp' };
---

<section class="streak">
    <div class="bg-grid"></div>

    <div class="streak-inner">
        <div class="streak-text">
            <h2 class="title">
                {t.title.split(' ').slice(0, -1).join(' ')} <span class="title-accent">{t.title.split(' ').at(-1)}</span>
            </h2>
            <p class="description">
                {t.description} <span class="description-highlight">{t.descriptionHighlight}</span>
            </p>

            <div class="countdown-row">
                <div class="countdown-box">
                    <Icon name="mdi:clock-alert-outline" class="countdown-icon" />
                    <span id="cookie-countdown" class="countdown-text">{t.countdownPrefix}</span>
                </div>
                <p class="tomorrow-note">{t.tomorrowNote}</p>
            </div>
        </div>

        <div class="calendar-card">
            <div class="calendar-glow"></div>

            <div class="calendar-grid">
                {
                    Array.from({ length: 12 }).map((_, i) => {
                        const img = imgMap[i] ?? 'cookie-closed.webp';
                        const filled = i < 10;
                        return (
                            <div class:list={['calendar-cell', { filled, today: i === 10 }]}>
                                {filled && i !== 10 && (
                                    <img src={`/assets/apps/${appId}/${img}`} alt="cookie" class="cell-img" />
                                )}
                                {i === 10 && (
                                    <div class="today-indicator">
                                        <span class="today-label">{t.todayLabel}</span>
                                    </div>
                                )}
                            </div>
                        );
                    })
                }
            </div>

            <div class="calendar-footer">
                <div class="calendar-stat">
                    <div class="stat-label">{t.altarLabel}</div>
                    <div class="stat-value">{t.dayPrefix} 10</div>
                </div>
                <div class="calendar-stat right">
                    <div class="stat-label">{t.nextMilestoneLabel}</div>
                    <div class="stat-value muted">{t.dayPrefix} 14</div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    function updateCountdown(prefix: string) {
        const now = new Date();
        const tomorrow = new Date(now);
        tomorrow.setDate(tomorrow.getDate() + 1);
        tomorrow.setHours(0, 0, 0, 0);

        const diff = tomorrow.getTime() - now.getTime();
        const h = Math.floor(diff / 3600000);
        const m = Math.floor((diff % 3600000) / 60000);
        const s = Math.floor((diff % 60000) / 1000);

        const el = document.getElementById('cookie-countdown');
        if (el) el.textContent = `${prefix} ${h}h ${m}m ${s}s`;
    }

    const el = document.getElementById('cookie-countdown');
    const prefix = el?.textContent ?? '';
    setInterval(() => updateCountdown(prefix), 1000);
    updateCountdown(prefix);
</script>
