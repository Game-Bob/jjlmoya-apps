---
import type { FortuneCookieEvents } from '../types';

interface EventColors {
    primary: string;
    accent: string;
    bgFrom: string;
    bgTo: string;
}

const EVENT_COLORS: EventColors[] = [
    {
        primary: 'var(--fc-event-0-primary)',
        accent: 'var(--fc-event-0-accent)',
        bgFrom: 'var(--fc-event-0-bg-from)',
        bgTo: 'var(--fc-event-0-bg-to)',
    },
    {
        primary: 'var(--fc-event-1-primary)',
        accent: 'var(--fc-event-1-accent)',
        bgFrom: 'var(--fc-event-1-bg-from)',
        bgTo: 'var(--fc-event-1-bg-to)',
    },
];

interface Props {
    t: FortuneCookieEvents;
    appId: string;
}

const { t, appId } = Astro.props;

const eventImages = ['cookie-valentine.webp', 'cookie-lunar-cracked.webp'];
---

<section class="events">
    <div class="events-inner">
        <div class="events-header">
            <h2 class="title">{t.title}</h2>
            <div class="divider"></div>
            <p class="subtitle">{t.subtitle}</p>
        </div>

        <div class="events-grid">
            {
                t.items.map((event, i) => {
                    const colors = EVENT_COLORS[i % EVENT_COLORS.length]!;
                    const img = eventImages[i % eventImages.length]!;
                    return (
                        <div class="event-card">
                            <div
                                class="event-bg"
                                style={`background-image: linear-gradient(135deg, ${colors.bgFrom} 0%, ${colors.bgTo} 100%);`}
                            />
                            <div class="event-shine" />
                            <div class="event-content">
                                <div class="event-date-wrapper">
                                    <span class="event-date" style={`color: ${colors.primary}`}>
                                        {event.date}
                                    </span>
                                </div>
                                <h3 class="event-name" style={`color: ${colors.accent}`}>
                                    {event.name}
                                </h3>
                                <p class="event-description">{event.description}</p>
                                <div class="event-img-wrapper">
                                    <div
                                        class="event-img-glow"
                                        style={`background-color: ${colors.primary}`}
                                    />
                                    <img
                                        src={`/assets/apps/${appId}/${img}`}
                                        alt={event.name}
                                        class="event-img"
                                    />
                                </div>
                            </div>
                        </div>
                    );
                })
            }
        </div>
    </div>
</section>
