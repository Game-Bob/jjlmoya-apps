---
import { Icon } from 'astro-icon/components';
import type { FortuneCookieFooter } from '../types';

interface Props {
    t: FortuneCookieFooter;
    stores: { googlePlay?: string; appStore?: string };
}

const { t, stores } = Astro.props;
---

<footer class="app-footer">
    <div class="footer-glow"></div>

    <div class="footer-inner">
        <div class="footer-cta">
            <h3 class="footer-title">{t.title}</h3>
            <p class="footer-subtitle">{t.subtitle}</p>
        </div>

        <div class="store-buttons">
            {
                stores.appStore && (
                    <a href={stores.appStore} target="_blank" class="store-btn">
                        <Icon name="mdi:apple" class="store-icon" />
                        <div class="store-text">
                            <span class="store-prefix">{t.downloadPrefix}</span>
                            <span class="store-name">App Store</span>
                        </div>
                    </a>
                )
            }
            {
                stores.googlePlay && (
                    <a href={stores.googlePlay} target="_blank" class="store-btn">
                        <Icon name="mdi:google-play" class="store-icon" />
                        <div class="store-text">
                            <span class="store-prefix">{t.downloadPrefix}</span>
                            <span class="store-name">Google Play</span>
                        </div>
                    </a>
                )
            }
        </div>
    </div>
</footer>
