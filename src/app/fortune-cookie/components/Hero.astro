---
import { Icon } from 'astro-icon/components';
import type { FortuneCookieHero } from '../types';

interface Props {
    t: FortuneCookieHero;
    stores: { googlePlay?: string; appStore?: string };
    appId: string;
    appTitle: string;
}

const { t, stores, appId, appTitle } = Astro.props;
---

<section class="hero">
    <div class="hero-bg">
        <div class="glow glow-top"></div>
        <div class="glow glow-bottom"></div>
    </div>

    <div class="hero-content">
        <div class="icon-wrapper">
            <div class="icon-glow"></div>
            <img
                src={`/assets/apps/${appId}/icon.webp`}
                alt={appTitle}
                class="app-icon"
            />
        </div>

        <h1 class="tagline">{t.tagline}</h1>
        <p class="description">{t.description}</p>

        <div class="store-buttons">
            {
                stores.appStore && (
                    <a href={stores.appStore} target="_blank" class="store-btn">
                        <Icon name="mdi:apple" class="store-icon" />
                        <span>App Store</span>
                    </a>
                )
            }
            {
                stores.googlePlay && (
                    <a href={stores.googlePlay} target="_blank" class="store-btn">
                        <Icon name="mdi:google-play" class="store-icon" />
                        <span>Google Play</span>
                    </a>
                )
            }
        </div>
    </div>

    <div class="scroll-indicator">
        <Icon name="mdi:chevron-down" class="scroll-icon" />
    </div>
</section>
