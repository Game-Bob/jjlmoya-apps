---
import type { KnownLocale } from '../../types';
import { lexiCrashEntry } from './entry';
import { localizedAppStoreUrl } from '../../app-store';
import './lexi-crash.css';
import Background from './components/Background.astro';
import Hero from './components/Hero.astro';
import GameModes from './components/GameModes.astro';
import SocialProof from './components/SocialProof.astro';
import Roadmap from './components/Roadmap.astro';
import FinalCTA from './components/FinalCTA.astro';

interface Props {
    locale: KnownLocale;
}

const { locale } = Astro.props;

const loaders = {
    es: () => import('./i18n/es').then((m) => m.landingContent),
    en: () => import('./i18n/en').then((m) => m.landingContent),
    fr: () => import('./i18n/fr').then((m) => m.landingContent),
    de: () => import('./i18n/de').then((m) => m.landingContent),
    it: () => import('./i18n/it').then((m) => m.landingContent),
    pt: () => import('./i18n/pt').then((m) => m.landingContent),
    nl: () => import('./i18n/nl').then((m) => m.landingContent),
    sv: () => import('./i18n/sv').then((m) => m.landingContent),
    pl: () => import('./i18n/pl').then((m) => m.landingContent),
    id: () => import('./i18n/id').then((m) => m.landingContent),
    tr: () => import('./i18n/tr').then((m) => m.landingContent),
    ru: () => import('./i18n/ru').then((m) => m.landingContent),
    ja: () => import('./i18n/ja').then((m) => m.landingContent),
    ko: () => import('./i18n/ko').then((m) => m.landingContent),
    zh: () => import('./i18n/zh').then((m) => m.landingContent),
};

const t = await (loaders[locale] ?? loaders.en)();
const { stores: baseStores, id: appId } = lexiCrashEntry;

const stores = {
    ...baseStores,
    appStore: baseStores.appStore ? localizedAppStoreUrl(baseStores.appStore, locale) : undefined,
};
---

<div class="lc-landing">
    <Background />
    <Hero t={t.hero} {stores} />
    <GameModes t={t.gameModes} {appId} />
    <SocialProof t={t.socialProof} {appId} />
    <Roadmap t={t.roadmap} />
    <FinalCTA t={t.finalCta} {stores} />
</div>
